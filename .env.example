# Базовый URL бэкенда (опционально).
# Не задавать — запросы идут на тот же хост по относительному пути /api (подходит, когда nginx/прокси отдаёт фронт и проксирует /api на бэкенд).
# Задать — если API на другом домене, например: https://api.example.com/api
# VITE_API_URL=https://api.example.com/api

# Ссылка приглашения бота на сервер (Discord OAuth2 invite URL)
# Используется на странице установки шаблона (Шаг 2)
# VITE_BOT_INVITE_URL=https://discord.com/api/oauth2/authorize?client_id=YOUR_CLIENT_ID&permissions=8&scope=bot%20applications.commands
